# PostgreSQL
POSTGRES_USER=emplai
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=emplai
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Backend
BACKEND_PORT=8000
JWT_SECRET=change-me-to-a-32-plus-character-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24
REGISTRATION_ENABLED=true
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# GigaChat (https://developers.sber.ru/portal/products/gigachat-api)
GIGACHAT_CREDENTIALS=
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_MODEL=Embeddings
GIGACHAT_VERIFY_SSL=false

# Matching
MATCH_SCORE_THRESHOLD=85
LLM_CONCURRENCY=5
VECTOR_PREFILTER_K=30
SCORING_TOP_K=15
DEFAULT_MATCH_TOP_N=10
MAX_MATCH_TOP_N=50
